# ============================================
# Treasury Intelligence Dashboard — Environment
# ============================================
# These values are NOT read by the static site.
# They are deployed as Cloudflare Worker secrets.
# ============================================

# FRED API Key (required)
# Sign up free: https://fred.stlouisfed.org/docs/api/api_key.html
# Provides: Treasury yields (3M-30Y), ON RRP, IG/HY credit spreads,
#           macro indicators (CPI, PPI, GDP, unemployment, M2, etc.)
# Set via:  npx wrangler secret put FRED_API_KEY
FRED_API_KEY=your_fred_api_key_here

# NewsAPI Key (optional — enhances news feed)
# Sign up free: https://newsapi.org/register
# Provides: Additional financial news beyond government RSS feeds
# Set via:  npx wrangler secret put NEWSAPI_KEY
NEWSAPI_KEY=your_newsapi_key_here

# Cloudflare Worker URL (assigned after first deploy)
# After running `npx wrangler deploy`, edit docs/app.js line 14:
#   var WORKER_URL = 'https://treasury-proxy.YOUR_SUBDOMAIN.workers.dev';
WORKER_URL=https://treasury-proxy.YOUR_SUBDOMAIN.workers.dev

# ============================================
# FREE APIs (no key needed):
#   Yahoo Finance — equities, commodities, forex, DXY, VIX
#   NY Fed API    — SOFR, EFFR
#   Federal Reserve RSS — press releases
#   BLS RSS       — economic data releases
# ============================================
